{
  "name": "convoyar",
  "private": true,
  "version": "0.1.0",
  "description": "Logística colaborativa para organizaciones: quién lleva a quién, optimizado y gratis de operar.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --mode single",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler pages deploy dist --project-name convoyar-web --branch main"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@supabase/supabase-js": "^2.110.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "~5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-singlefile": "^2.0.2",
    "vitest": "^2.1.2"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
