# entorno / editor
# .env con secretos reales NUNCA se commitea. .env.single (solo VITE_SINGLE=1)
# es la única excepción trackeada: es un flag de build, no lleva secretos.
.env
.env.local
.env.*.local
!.env.single
server/.env
.DS_Store
Thumbs.db
*.log

# Firebase / Google — secretos que NUNCA van al repo
google-services.json
GoogleService-Info.plist
convoyar-*.json
*-firebase-adminsdk-*.json
*serviceaccount*.json

# Android (Capacitor) — el proyecto android/ (fuentes) SÍ se commitea;
# lo de abajo son secretos de firma y artefactos de build que NO van al repo.
android/keystore.properties
*.keystore
*.jks
android/app/release/
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/app/src/main/assets/public/

# Playwright MCP (screenshots/consola de prueba)
.playwright-mcp/
